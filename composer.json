{
    "name": "syedamirali/php-template",
    "description": "Custom PHP MVC-style template with routing, Eloquent models, and environment configuration.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "illuminate/database": "*",
        "nesbot/carbon": "*",
        "vlucas/phpdotenv": "*"
    },
    "autoload": {
        "classmap": [
            "app/",
            "configs/",
            "migrations/",
            "utility/"
        ]
    },
    "scripts": {
        "serve": "php -S localhost:8173 server.php",
        "start": "@serve"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
