# cPanel / Apache entry point for the custom PHP template project.

Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preserve Authorization headers for Bearer token API requests.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Block direct access to private framework and dependency folders.
    RewriteRule ^(\.git|\.cursor|app|configs|migrations|node_modules|resources|routes|settings|storage|utility|vendor)(/|$) - [F,L]

    # Block direct access to project metadata and environment files.
    RewriteRule ^(\.env(\..*)?|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|bun\.lockb)$ - [F,L]

    # Treat ./public as the static web root.
    # Example: /assets/css/app.css -> /public/assets/css/app.css
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.+\.(css|js|json|png|jpe?g|gif|svg|webp|ico|woff2?|ttf|txt|pdf))$ public/$1 [L,NC]

    # Allow direct files that are intentionally placed in the document root.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Send all application routes to the front controller.
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|png|jpe?g|gif|svg|webp|ico|woff2?|ttf)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>
